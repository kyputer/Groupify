# Two-stage development Dockerfile for Groupify (hot reload, root user, dev tools)
FROM node:20-bullseye AS builder

# Install MariaDB client and dev tools
RUN apt-get update && apt-get install -y mariadb-client && rm -rf /var/lib/apt/lists/*

# Set working directory for builder
WORKDIR /build

# Install global dev dependencies (e.g. nodemon)
RUN npm install -g nodemon

# Copy groupify package files and install dependencies (ensure using public registry)
RUN mkdir -p /build/groupify
WORKDIR /build/groupify

# Copy package files (package.json and package-lock.json if present)
COPY groupify/package*.json ./

# Configure npm to use public registry and non-interactive behavior
ENV NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
ENV NPM_CONFIG_PROGRESS=false
ENV NPM_CONFIG_AUDIT=false
ENV NPM_CONFIG_FUND=false

# Install deps: use npm ci when package-lock.json is present for reproducible installs,
# otherwise fall back to npm install. Keep devDependencies for dev image (hot reload).
RUN if [ -f package-lock.json ]; then \      npm ci --no-audit --no-fund --fetch-retries=5 --fetch-retry-factor=2; \    else \      npm install --no-audit --no-fund --fetch-retries=5 --fetch-retry-factor=2; \    fi

# Copy app source
WORKDIR /build
COPY groupify ./groupify

# --- Final image ---
FROM node:20-bullseye

# Install only system packages via apt-get (remove wait-port from here)
RUN apt-get update && apt-get install -y mariadb-client && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app/groupify

# Copy package files first (better Docker layer caching)
COPY groupify/package*.json ./

# Install dependencies including wait-port via npm
ENV NPM_CONFIG_AUDIT=false NPM_CONFIG_FUND=false NPM_CONFIG_PROGRESS=false
RUN if [ -f package-lock.json ]; then npm ci --silent; else npm install --silent; fi

# Install wait-port globally via npm (not apt-get)
RUN npm install -g wait-port

# Copy app source
COPY groupify ./

EXPOSE 3000

# Wait for DB then start dev server
CMD ["sh", "-c", "wait-port db:3306 && npm run dev"]
